# Redeploy
# Set to false to hide project links or GitHub links
NEXT_PUBLIC_SHOW_PROJECT_LINKS=true
NEXT_PUBLIC_SHOW_GITHUB_LINKS=true

# SMTP Configuration for Contact Form
# Gmail example (requires app-specific password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
SMTP_FROM=your-email@gmail.com

# For Gmail:
# 1. Enable 2-factor authentication
# 2. Generate app-specific password at: https://myaccount.google.com/apppasswords
# 3. Use that password as SMTP_PASS

# Other popular SMTP services:
# Outlook: smtp-mail.outlook.com (port 587)
# Yahoo: smtp.mail.yahoo.com (port 587 or 465)
# Zoho: smtp.zoho.com (port 587)
# SendGrid: smtp.sendgrid.net (port 587)